{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@lib/*": ["./scripts/lib/*"]
    }
  },
  "include": [
    "scripts/**/*.ts",
    "vitest.config.ts",
    "vitest.integration.config.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "site"
  ]
}
