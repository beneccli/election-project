# Pipeline drafts (intentionally not committed)
candidates/**/versions/*/sources.md.draft
candidates/**/versions/*/aggregated.draft.json
candidates/**/versions/*/aggregated.*.draft.json

# Manual-mode bundles (regenerated, should not be committed)
candidates/**/versions/*/_manual/*
!candidates/**/versions/*/_manual/README.md
candidates/**/versions/*/_manual-aggregation/*
!candidates/**/versions/*/_manual-aggregation/README.md
candidates/**/versions/*/_translation/*
!candidates/**/versions/*/_translation/README.md
candidates/**/current

